{
  "name": "@wd0517/opencli",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Make any website your CLI. AI-powered.",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "opencli": "dist/main.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc && npm run clean-yaml && npm run copy-yaml",
    "clean-yaml": "find dist/clis -name '*.yaml' -o -name '*.yml' 2>/dev/null | xargs rm -f",
    "copy-yaml": "find src/clis -name '*.yaml' -o -name '*.yml' | while read f; do d=\"dist/${f#src/}\"; mkdir -p \"$(dirname \"$d\")\"; cp \"$f\" \"$d\"; done",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "browser",
    "web",
    "ai",
    "playwright"
  ],
  "author": "wd0517",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wd0517/opencli.git"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
